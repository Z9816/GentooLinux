###########################################################################

prefix=/usr
exec_prefix=${prefix}
libdir=/usr/lib64
includedir=${prefix}/include
supported_protocols="DICT FILE FTP FTPS HTTP HTTPS IMAP IMAPS IPFS IPNS MQTT MQTTS POP3 POP3S RTSP SMTP SMTPS TFTP WS WSS"
supported_features="alt-svc AsynchDNS HSTS HTTPS-proxy HTTPSRR IPv6 Largefile libz NTLM PSL SSL threadsafe TLS-SRP UnixSockets"

Name: libcurl
URL: https://curl.se/
Description: Library to transfer files with HTTP, FTP, etc.
Version: 8.19.0
Requires: 
Requires.private: zlib,openssl,libpsl,libcares
Libs: -L${libdir} -lcurl 
Libs.private:  -lcares -lpsl -lssl -lcrypto -lssl -lcrypto -lz
Cflags: -I${includedir} 
Cflags.private: -DCURL_STATICLIB
